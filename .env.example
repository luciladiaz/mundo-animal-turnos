# DATABASE_URL: conexión pooled (transaction mode, puerto 6543) — para runtime.
# DIRECT_URL: conexión directa (puerto 5432) — solo para `prisma migrate`.
# En Supabase, el botón "Connect" del proyecto te da ambas URLs.
DATABASE_URL="postgresql://usuario:password@host-pooler:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://usuario:password@host-directo:5432/postgres"

NEXTAUTH_SECRET="generar-con: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

RESEND_API_KEY=""
RESEND_FROM_EMAIL="turnos@tudominio.com"

ADMIN_SEED_EMAIL="admin"
ADMIN_SEED_PASSWORD="cambiar-esto"

# Email real donde llega el aviso de "nuevo turno reservado" (independiente del usuario de login de arriba)
ADMIN_NOTIFICACION_EMAIL="admin@tudominio.com"

APP_TIMEZONE="America/Argentina/Buenos_Aires"
